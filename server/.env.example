DATABASE_URL=postgresql://user:password@localhost:5432/campos_munos
JWT_SECRET=change-me-to-a-random-64-char-string
FRONTEND_URL=http://localhost:5173
ADMIN_EMAIL=admin@camulaw.com
ADMIN_INITIAL_PASSWORD=changeme
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=contact@camulaw.com
PORT=3000
# REQUIRED in production. Secure cookies, DB SSL, and the admin-seed guard all
# key off this being exactly "production". If unset on the live host, login
# cookies won't be secure and the seed falls back to defaults. Set it on Railway.
NODE_ENV=production
